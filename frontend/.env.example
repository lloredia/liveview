# LiveView Web — Environment Variables
# Copy to .env.local and adjust as needed.

# Backend API URL (required for leagues, matches, news).
# Local: NEXT_PUBLIC_API_URL=http://localhost:8000
# No local backend? Use deployed API so the app works:
#   NEXT_PUBLIC_API_URL=https://backend-api-production-8b9f.up.railway.app
NEXT_PUBLIC_API_URL=http://localhost:8000

# WebSocket URL for real-time updates
NEXT_PUBLIC_WS_URL=ws://localhost:8000/v1/ws

# ── Sentry Error Tracking (optional but recommended) ──────
# Sign up at https://sentry.io and create a project for your app
# Copy your DSN from project settings
# NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Enable/disable Sentry (defaults to true in production)
# NEXT_PUBLIC_SENTRY_ENABLED=true

# Add redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── OAuth: Apple (Sign in with Apple) ────────────────────
# Apple does not support http://localhost; use HTTPS (e.g. ngrok) or deploy to test.
# Option A: Static JWT — run: npm run gen:apple-secret (set APPLE_* below first), then paste output as APPLE_SECRET.
# Option B: Use same APPLE_ID as clientId; JWT in APPLE_SECRET expires in 180 days — regenerate and redeploy.
# APPLE_ID=com.liveview.tracker.web
# APPLE_SECRET=
# For gen:apple-secret you also need: APPLE_TEAM_ID, APPLE_KEY_ID, APPLE_PRIVATE_KEY or APPLE_PRIVATE_KEY_PATH

# iOS app (Capacitor): URL loaded in the native shell. Only used when running cap sync.
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
